            else:\par
                for j in range(len(hypothesis)):\par
                    if hypothesis[j] != X[i][j]:\par
                        hypothesis[j] = "?"\par
\par
            print(f"After Positive Example \{i+1\}: \{hypothesis\}")\par
\par
    print("\\nFinal Hypothesis:")\par
    print(hypothesis)\par
\par
